{
  "name": "smart-contracts",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:solidity": "npx hardhat test contracts/CortexYieldVault.t.sol",
    "deploy": "npx hardhat run scripts/deploy.ts --network somniaTestnet",
    "deploy:ignition": "npx hardhat ignition deploy ignition/modules/CortexYieldVault.ts --network somniaTestnet",
    "verify": "npx hardhat run scripts/verify.ts --network somniaTestnet",
    "verify:vault": "npx hardhat run scripts/verify-vault.ts --network somniaTestnet",
    "clean": "npx hardhat clean",
    "size": "npx hardhat size-contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.3",
    "@nomicfoundation/hardhat-ignition": "^3.0.9",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.3",
    "@nomicfoundation/hardhat-typechain": "^3.0.4",
    "@nomicfoundation/hardhat-verify": "^3.0.19",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "chai": "^6.2.2",
    "ethers": "^6.16.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.1.12",
    "mocha": "^11.7.5",
    "typescript": "~5.8.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "viem": "^2.37.13"
  }
}
